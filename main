import pygame
import sys
import random
# ---------- INIT ----------
pygame.init()
info = pygame.display.Info()
WIDTH = info.current_w
HEIGHT = info.current_h

# Полноэкранный режим
screen = pygame.display.set_mode((WIDTH, HEIGHT), pygame.FULLSCREEN)
pygame.display.set_caption("DBPG")

clock = pygame.time.Clock()
font_size = max(24, WIDTH // 50)
font = pygame.font.SysFont("arial", font_size)



BASE_WIDTH = 1280
BASE_HEIGHT = 720

def scale_pos(x, y):
    return (
        int(x / BASE_WIDTH * WIDTH),
        int(y / BASE_HEIGHT * HEIGHT)
    )

# ---------- GAME STATE ----------
location = "home"

inventory = {"flower": 0, "cake": 0, "teaservice": 0, "magictea": 0}

quests = {
    "collect_flowers": False,
    "bring_cake": False
}

trader_intro_done = False
trader_menu_active = False
trader_menu_index = 0

quest_menu_active = False
quest_menu_index = 0
quest_intro_done = False
quest_items_delivered = {
    "cake": False,
    "magictea": False,
    "teaservice": False
}

troll_intro_done = False
troll_choice_active = False
troll_choice_index = 0
troll_dialog_expects_choice = False
troll_bridge_solved = False
troll_bridge_portal_added = False

# ---------- LOAD ASSETS ----------
player_img = pygame.image.load("assets/persons/mainpersmini2.png").convert_alpha()
player_rect = player_img.get_rect(center=(WIDTH // 2, HEIGHT // 2))

portal_img = pygame.image.load("assets/subject/portal.png").convert_alpha()
portal2_img = pygame.image.load("assets/subject/portal2.png").convert_alpha()
flower_img = pygame.image.load("assets/subject/flover.png").convert_alpha()
teaservice_img = pygame.transform.scale(
    pygame.image.load("assets/subject/Teaservice.png").convert_alpha(),
    scale_pos(106, 136)
)
magictea_img = pygame.transform.scale(
    pygame.image.load("assets/subject/magictea.png").convert_alpha(),
    scale_pos(106, 126)
)
mountain_close_img = pygame.transform.scale(
    pygame.image.load("assets/subject/mountainclose.png").convert_alpha(),
    scale_pos(700, 400)
)
mountain_open_img = pygame.transform.scale(
    pygame.image.load("assets/subject/mountainopen.png").convert_alpha(),
    scale_pos(700, 400)
)

backgrounds = {
    "home": pygame.transform.scale(
        pygame.image.load("assets/backgrounds/back1.png").convert(), (WIDTH, HEIGHT)
    ),
    "market": pygame.transform.scale(
        pygame.image.load("assets/backgrounds/back2.png").convert(), (WIDTH, HEIGHT)
    ),
    "forest": pygame.transform.scale(
        pygame.image.load("assets/backgrounds/back3.png").convert(), (WIDTH, HEIGHT)
