# ---------- NPC CLASS ----------
class NPC:
    def __init__(self, image_path, pos, dialog):
        self.image = pygame.image.load(image_path).convert_alpha()
        self.rect = self.image.get_rect(center=pos)
        self.interaction_rect = self.rect.inflate(120, 120)
        self.dialog = dialog
        self.dialog_index = 0
        self.show_dialog = False

    def update(self):
        self.interaction_rect.center = self.rect.center

    def draw(self):
        screen.blit(self.image, self.rect)

    def can_interact(self, player_rect):
        return self.interaction_rect.colliderect(player_rect)

    def start_dialog(self, dialog):
        self.dialog = dialog
        self.dialog_index = 0
        self.show_dialog = True
    def next_dialog(self):
        if self.dialog_index < len(self.dialog) - 1:
            self.dialog_index += 1
            return "continue"
        self.show_dialog = False
        self.dialog_index = 0
        return "end"

    def current_line(self):
        return self.dialog[self.dialog_index]


# ---------- PORTAL ----------
class Portal:
    def init(self, pos, target_location, spawn_pos, image=None):
        self.image = image if image is not None else portal_img
        self.rect = self.image.get_rect(center=pos)
        self.target = target_location
        self.spawn = spawn_pos

    def draw(self):
        screen.blit(self.image, self.rect)

    def check(self, player_rect):
        return self.rect.colliderect(player_rect)

# ---------- MOUNTAIN PUZZLE ----------
class MountainGate:
    def __init__(self, pos):
        self.closed_image = mountain_close_img
        self.open_image = mountain_open_img
        self.rect = self.closed_image.get_rect(center=pos)
        self.interaction_rect = self.rect.inflate(120, 120)
        self.opened = False

    def draw(self):
        image = self.open_image if self.opened else self.closed_image
        screen.blit(image, self.rect)

    def can_interact(self, player_rect):
        return (not self.opened) and self.interaction_rect.colliderect(player_rect)

class MountainPuzzle:
    def __init__(self):
        self.active = False
        self.solved = False
        self.selected = 0
        self.shape_names = ["square", "triangle", "oval"]
        self.shape_angles = {name: 0 for name in self.shape_names}
        self.locked_shapes = set()
        self.slot_order = []
        self.slot_angles = {}
        self.reset()

 def reset(self):
        self.selected = 0
        self.shape_angles = {name: random.choice([0, 15, 30, 45, 60, 75]) for name in self.shape_names}
        self.locked_shapes = set()
        self.slot_order = self.shape_names[:]
        random.shuffle(self.slot_order)
        self.slot_angles = {
            "square": random.choice([0, 90, 180, 270]),
            "triangle": random.choice([0, 120, 240]),
            "oval": random.choice([0, 180])
        }

    def start(self):
        self.reset()
        self.active = True

    def rotate_selected(self):
        shape = self.shape_names[self.selected]
        if shape not in self.locked_shapes:
            self.shape_angles[shape] = (self.shape_angles[shape] + 15) % 360
            self.try_lock(shape)

    def select_next(self, step):
        for _ in self.shape_names:
            self.selected = (self.selected + step) % len(self.shape_names)
            if self.shape_names[self.selected] not in self.locked_shapes:
                break

    def select_next_unlocked(self):
        for i, shape in enumerate(self.shape_names):
            if shape not in self.locked_shapes:
                self.selected = i
                return

    def is_angle_correct(self, shape):
        angle = self.shape_angles[shape] % 360
        slot_angle = self.slot_angles[shape] % 360
        symmetry = {
            "square": 90,
            "triangle": 120,
            "oval": 180
        }[shape]
        return (angle - slot_angle) % symmetry == 0

    def try_lock(self, shape):
        if self.is_angle_correct(shape):
            self.locked_shapes.add(shape)
            if len(self.locked_shapes) == len(self.shape_names):
                self.solved = True
                self.active = False
            else:
                self.select_next_unlocked()

    def draw_shape(self, surface, shape, center, angle, color, outline=0):
        temp = pygame.Surface((150, 150), pygame.SRCALPHA)
        cx, cy = 75, 75

       if shape == "square":
            points = [(35, 35), (115, 35), (115, 115), (35, 115)]
            pygame.draw.polygon(temp, color, points, outline)
        elif shape == "triangle":
            points = [(75, 25), (120, 115), (30, 115)]
            pygame.draw.polygon(temp, color, points, outline)
        elif shape == "oval":
            pygame.draw.ellipse(temp, color, pygame.Rect(30, 45, 90, 60), outline)

        rotated = pygame.transform.rotate(temp, -angle)
        rect = rotated.get_rect(center=center)
        surface.blit(rotated, rect)

    def draw(self):
        overlay = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA)
        overlay.fill((0, 0, 0, 170))
        screen.blit(overlay, (0, 0))

        box_size = min(700, WIDTH - 60, HEIGHT - 60)
        box = pygame.Rect(0, 0, box_size, box_size)
        box.center = (WIDTH // 2, HEIGHT // 2)

        pygame.draw.rect(screen, (28, 32, 38), box)
        pygame.draw.rect(screen, (235, 235, 235), box, 4)

        gap = box_size // 4
        top_y = box.y + box_size // 3
        slot_y = box.y + box_size * 2 // 3
        slot_positions = [
            (box.x + gap, slot_y),
            (box.x + gap * 2, slot_y),
            (box.x + gap * 3, slot_y)
        ]

        for i, shape in enumerate(self.slot_order):
            center = slot_positions[i]
            self.draw_shape(screen, shape, center, self.slot_angles[shape], (120, 130, 145), 6)

        for i, shape in enumerate(self.shape_names):
            x = box.x + gap * (i + 1)
            y = top_y
            if shape in self.locked_shapes:
                slot_index = self.slot_order.index(shape)
                x, y = slot_positions[slot_index]

            color = (255, 214, 84) if i == self.selected else (230, 230, 230)
            if shape in self.locked_shapes:
                color = (110, 220, 150)

            if i == self.selected and shape not in self.locked_shapes:
                marker = pygame.Rect(0, 0, 130, 130)
                marker.center = (x, y)
                pygame.draw.rect(screen, (255, 214, 84), marker, 3)

            self.draw_shape(screen, shape, (x, y), self.shape_angles[shape], color)

mountain_gate = MountainGate(scale_pos(950, 190))
mountain_puzzle = MountainPuzzle()
mountain_portal = Portal(scale_pos(1080, 190), "vilka3", scale_pos(500, 360), portal2_img)

# ---------- TROLL RIDDLES ----------
class TrollRiddles:
    def __init__(self):
        self.active = False
        self.selected = 0
        self.questions = [
            {"text": "1) 7*7=", "answer": "49"},
            {"text": "2) 293+7=", "answer": "300"},
            {"text": ["3) I am a pet. I like mice. I have nine lives.", "I purr and meow. What am I-"], "answer": "cat"}
        ]
        self.inputs = ["", "", ""]

    def start(self):
        self.active = True
        self.selected = 0
        self.inputs = ["", "", ""]

    def handle_key(self, event):
        if event.key == pygame.K_UP:
            self.selected = (self.selected - 1) % len(self.questions)
        elif event.key == pygame.K_DOWN:
            self.selected = (self.selected + 1) % len(self.questions)
        elif event.key == pygame.K_BACKSPACE:
            self.inputs[self.selected] = self.inputs[self.selected][:-1]
        elif event.key == pygame.K_RETURN:
            if self.is_solved():
                self.active = False
        else:
            if event.unicode and len(self.inputs[self.selected]) < 20:
                self.inputs[self.selected] += event.unicode

        if self.is_solved():
            self.active = False

    def is_solved(self):
        for i, question in enumerate(self.questions):
            if self.inputs[i].strip().lower() != question["answer"]:
                return False
        return True

    def draw(self):
        overlay = pygame.Surface((WIDTH, HEIGHT), pygame.SRCALPHA)
        overlay.fill((0, 0, 0, 170))
        screen.blit(overlay, (0, 0))

        box_size = min(700, WIDTH - 60, HEIGHT - 60)
        box = pygame.Rect(0, 0, box_size, box_size)
        box.center = (WIDTH // 2, HEIGHT // 2)

        pygame.draw.rect(screen, (26, 30, 36), box)
        pygame.draw.rect(screen, (235, 235, 235), box, 4)

        title = font.render("Troll riddles", True, (255, 230, 120))
        screen.blit(title, (box.x + 40, box.y + 35))

        start_y = box.y + 120
        row_gap = max(95, box_size // 6)

        for i, question in enumerate(self.questions):
            y = start_y + i * row_gap
            selected = i == self.selected
            color = (255, 230, 120) if selected else (255, 255, 255)
            question_lines = question["text"] if isinstance(question["text"], list) else [question["text"]]
            for line_index, line in enumerate(question_lines):
                text = font.render(line, True, color)
                screen.blit(text, (box.x + 45, y + line_index * 30))

            field = pygame.Rect(box.x + 45, y + 42 + (len(question_lines) - 1) * 30, box_size - 90, 42)
            pygame.draw.rect(screen, (12, 14, 18), field)
            pygame.draw.rect(screen, color if selected else (150, 150, 150), field, 2)

            shown = self.inputs[i] if self.inputs[i] else "?"
            answer_text = font.render(shown, True, (230, 230, 230))
            screen.blit(answer_text, (field.x + 12, field.y + 7))

troll_riddles = TrollRiddles()

def draw_troll_choice():
    box = pygame.Rect(80, HEIGHT - 240, WIDTH - 160, 200)
    pygame.draw.rect(screen, (0, 0, 0), box)
    pygame.draw.rect(screen, (255, 255, 255), box, 2)

    title = font.render("Solve the riddles?", True, (200, 200, 200))
    screen.blit(title, (box.x + 20, box.y + 10))

    options = ["Yes", "No"]
    for i, opt in enumerate(options):
        color = (255, 255, 0) if i == troll_choice_index else (255, 255, 255)
        screen.blit(font.render(opt, True, color), (box.x + 40, box.y + 60 + i * 50))
# ---------- UI ----------
def draw_dialog(speaker, text):
    box = pygame.Rect(80, HEIGHT - 170, WIDTH - 160, 120)
    pygame.draw.rect(screen, (0, 0, 0), box)
    pygame.draw.rect(screen, (255, 255, 255), box, 2)

    color = (200, 200, 50) if speaker == "npc" else (100, 200, 255)
    screen.blit(font.render(speaker.upper(), True, color), (box.x + 20, box.y + 10))
    screen.blit(font.render(text, True, (255, 255, 255)), (box.x + 20, box.y + 50))

def draw_trader_menu():
    box = pygame.Rect(80, HEIGHT - 240, WIDTH - 160, 200)
    pygame.draw.rect(screen, (0, 0, 0), box)
    pygame.draw.rect(screen, (255, 255, 255), box, 2)

    title = font.render("Choose an option:", True, (200, 200, 200))
    screen.blit(title, (box.x + 20, box.y + 10))

    options = ["Ask price again", "I brought flowers", "Exit"]

    for i, opt in enumerate(options):
        color = (255, 255, 0) if i == trader_menu_index else (255, 255, 255)
        screen.blit(font.render(opt, True, color),
                    (box.x + 40, box.y + 50 + i * 50))
def all_tea_party_items_delivered():
    return all(quest_items_delivered.values())

def get_quest_options():
    options = []


    if not quest_items_delivered["cake"]:
        if inventory["cake"] >= 1:
            options.append(("deliver_cake", "I brought the cake"))
        else:
            options.append(("hint_cake", "Where can I buy a cake?"))

    if not quest_items_delivered["magictea"]:
        if inventory["magictea"] >= 1:
            options.append(("deliver_magictea", "I brought a magic tea"))
        else:
            options.append(("hint_magictea", "Where can I find a magic tea?"))

    if not quest_items_delivered["teaservice"]:
        if inventory["teaservice"] >= 1:
            options.append(("deliver_teaservice", "I brought a tea service"))
        else:
            options.append(("hint_teaservice", "Where can I find a tea service?"))

    return options

def draw_quest_menu():
    box = pygame.Rect(80, HEIGHT - 240, WIDTH - 160, 200)
    pygame.draw.rect(screen, (0, 0, 0), box)
    pygame.draw.rect(screen, (255, 255, 255), box, 2)

    title = font.render("Choose an option:", True, (200, 200, 200))
    screen.blit(title, (box.x + 20, box.y + 10))

    options = get_quest_options()

    for i, option in enumerate(options):
        opt = option[1]
        color = (255, 255, 0) if i == quest_menu_index else (255, 255, 255)
        screen.blit(font.render(opt, True, color),
                    (box.x + 40, box.y + 50 + i * 50))

