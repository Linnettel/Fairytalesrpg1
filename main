    for npc in get_npcs_for_location():
        if player_rect.colliderect(npc.rect):
            player_rect = prev_rect
            break

    if location == "vilka2" and (not mountain_gate.opened) and player_rect.colliderect(mountain_gate.rect):
        player_rect = prev_rect

    # ---------- PORTALS ----------
    for portal in portals[location]:
        if portal.check(player_rect):
            location = portal.target
            player_rect.center = portal.spawn

    player_rect.clamp_ip(screen.get_rect())

