    "vilka": [
        Portal(scale_pos(100, 360), "home", scale_pos(500, 360)),
        Portal(scale_pos(650, 100), "market", scale_pos(500, 360)),
        Portal(scale_pos(1150, 360), "vilka1", scale_pos(300, 560)),
        Portal(scale_pos(650, 660), "vilkaa", scale_pos(150, 360))
    ],
    "vilka1": [
        Portal(scale_pos(100, 520), "vilka", scale_pos(500, 360)),
        Portal(scale_pos(1150, 520), "vilka2", scale_pos(500, 360))
    ],
    "vilka2": [Portal(scale_pos(100, 520), "vilka1", scale_pos(300, 560))],
    "vilka3": [Portal(scale_pos(100, 360), "vilka2", scale_pos(500, 360)),
               ],
    "vilkaa": [
        Portal(scale_pos(100, 660), "vilka", scale_pos(500, 360))
    ],
    "vilkab": [Portal(scale_pos(100, 360), "vilkaa", scale_pos(800, 360))]
}
troll_bridge_portal = Portal(scale_pos(1150, 360), "vilkab", scale_pos(500, 360))

def open_troll_bridge():
    global troll_bridge_portal_added
    if not troll_bridge_portal_added:
        portals["vilkaa"].append(troll_bridge_portal)
        troll_bridge_portal_added = True

def get_npcs_for_location():
    if location == "home":
        return [quest_npc]
    if location == "market":
        return [trader_npc]
    if location == "vilka1":
        return [npc11]
    if location == "vilkaa":
        return [troll_npc]
    return []

# ---------- GAME LOOP ----------
while True:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            sys.exit()

        if event.type == pygame.MOUSEWHEEL and mountain_puzzle.active:
            mountain_puzzle.rotate_selected()

        if event.type == pygame.MOUSEBUTTONDOWN and mountain_puzzle.active:
            if event.button in (4, 5):
                mountain_puzzle.rotate_selected()

        if event.type == pygame.KEYDOWN:
            #---Esc----
            if event.key == pygame.K_ESCAPE:
                if mountain_puzzle.active:
                    mountain_puzzle.active = False
                    continue
                pygame.quit()
                sys.exit()

            if mountain_puzzle.active:
                if event.key == pygame.K_LEFT:
                    mountain_puzzle.select_next(-1)
                elif event.key == pygame.K_RIGHT:
                    mountain_puzzle.select_next(1)
                elif event.key in (pygame.K_UP, pygame.K_SPACE, pygame.K_e):
                    mountain_puzzle.rotate_selected()
                continue

            if mountain_puzzle.solved and not mountain_gate.opened:
                mountain_gate.opened = True
                portals["vilka2"].append(mountain_portal)

            if troll_riddles.active:
                troll_riddles.handle_key(event)
                if troll_riddles.is_solved():
                    troll_bridge_solved = True
                    open_troll_bridge()
                    troll_npc.start_dialog(
                     [{"speaker": "troll", "text": "It's your bridge."}]
                    )
                continue

            if troll_choice_active:
                if event.key in (pygame.K_UP, pygame.K_DOWN):
                    troll_choice_index = (troll_choice_index + 1) % 2
                elif event.key in (pygame.K_e, pygame.K_RETURN):
                    if troll_choice_index == 0:
                        troll_riddles.start()
                    troll_choice_active = False
                continue

            if event.key == pygame.K_e and location == "vilka2":
                if mountain_gate.can_interact(player_rect):
                    mountain_puzzle.start()
                    continue
            if event.key == pygame.K_e and location == "vilkaa":
                if troll_npc.can_interact(player_rect):
                    if troll_npc.show_dialog:
                        if troll_npc.next_dialog() == "end" and troll_dialog_expects_choice:
                            troll_choice_active = True
                            troll_choice_index = 0
                            troll_dialog_expects_choice = False

                    elif not troll_bridge_solved:
                        if not troll_intro_done:
                            troll_npc.start_dialog([
                                {"speaker": "player", "text": "Hello."},
                                {"speaker": "troll", "text": "Hello."},
                                {"speaker": "player", "text": "What sort of bridge are you guarding?"},
                                {"speaker": "troll", "text": "This bridge leads to a magical tea."},
                                {"speaker": "player", "text": "Can I cross this bridge?"},
                                {"speaker": "troll", "text": "Yes, but you have to solve the riddles."}
                            ])
                            troll_intro_done = True
                        else:
                            troll_npc.start_dialog([
                                {"speaker": "troll", "text": "Do you still want to solve the riddles?"}
                            ])
                        troll_dialog_expects_choice = True
                    continue
